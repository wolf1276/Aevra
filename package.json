{
  "name": "aevra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "build:ext": "node scripts/build-extension.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build:ext && cd out && zip -r ../aevra-extension.zip .",
    "circuits": "node scripts/fetch-circuits.mjs",
    "smoke": "esbuild scripts/smoke.ts --bundle --platform=node --format=cjs --alias:@=./src --outfile=node_modules/.cache/smoke.cjs && node node_modules/.cache/smoke.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@avalabs/eerc-sdk": "^1.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "ethers": "^6.17.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "15.5.20",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "viem": "^2.55.2",
    "wagmi": "^3.7.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4",
    "@types/chrome": "^0.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
