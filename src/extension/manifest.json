{
  "manifest_version": 3,
  "name": "Aevra",
  "version": "0.1.0",
  "description": "Chrome extension wallet for Avalanche eERC confidential assets (Fuji testnet)",
  "action": {
    "default_popup": "index.html",
    "default_title": "Aevra"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": []
}
